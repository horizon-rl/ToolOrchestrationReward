# =============================================================================
# ToolOrchestrationReward Environment Configuration
# =============================================================================
# This is the ONLY .env file you need for both training and evaluation.
#
# Setup:
#   1. Copy this file: cp .env.example .env
#   2. Add your API key(s) below
#   3. Keys are loaded automatically by Python scripts
#   4. .env is gitignored (won't be committed)
# =============================================================================

# =============================================================================
# CORE: LLM API Keys (Required - need at least ONE)
# =============================================================================

# OpenAI (recommended for training)
OPENAI_API_KEY=sk-XXXXXX

# Anthropic (alternative)
ANTHROPIC_API_KEY=sk-XXXXXX

# =============================================================================
# TRAINING: Optional Cache Expansion (skip unless needed)
# =============================================================================

# RapidAPI Key - ONLY for expanding the cache (costs money!)
# Get free key: https://rapidapi.com/DataCrawler/api/booking-com15
#
# NOTE: Training works WITHOUT this!
# Existing 5,070 cache entries are sufficient for 200-300 training samples.
RAPID_API_KEY=

# =============================================================================
# EVALUATION: Additional Model APIs (optional - only for BFCL evaluation)
# =============================================================================
# These are ONLY needed if running BFCL evaluation commands like:
#   bfcl generate --model MODEL --test-category CATEGORY
#   bfcl evaluate --model MODEL --test-category CATEGORY
#
# For normal ToolOrchestrationReward training, you can skip this entire section!
# =============================================================================

# Google AI Studio (for Gemini models)
GOOGLE_API_KEY=

# Other model providers (uncomment if needed)
# NVIDIA_API_KEY=nvapi-XXXXXX
# GROK_API_KEY=xai-XXXXXX
# COHERE_API_KEY=
# DEEPSEEK_API_KEY=sk-XXXXXX
# MISTRAL_API_KEY=
# FIREWORKS_API_KEY=

# Web search (for BFCL web_search category only)
# SERPAPI_API_KEY=

# AWS (for Nova models only)
# AWS_SSO_PROFILE_NAME=

# Local inference server (optional)
# LOCAL_SERVER_ENDPOINT=localhost
# LOCAL_SERVER_PORT=1053

# Experiment tracking (optional)
# WANDB_BFCL_PROJECT=ENTITY:PROJECT
